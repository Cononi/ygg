{
  "name": "@cono-ai/ygg",
  "version": "1.0.0",
  "description": "Claude Code와 Codex용 ygg workflow 파일과 change 기반 개발 흐름을 관리하는 CLI 도구",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "ygg": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "scripts"
  ],
  "scripts": {
    "build:dashboard": "pnpm --filter @cono-ai/ygg-dashboard build",
    "build:server": "tsup",
    "build:copy": "node scripts/copy-dashboard.mjs",
    "build": "pnpm build:dashboard && pnpm build:server && pnpm build:copy",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude-code",
    "codex",
    "workflow",
    "cli"
  ],
  "author": "Cononi",
  "license": "MIT",
  "dependencies": {
    "@fastify/static": "^8.1.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "deepmerge-ts": "^7.1.3",
    "fastify": "^5.3.2",
    "glob": "^11.1.0",
    "handlebars": "^4.7.8",
    "nanoid": "^5.1.5",
    "open": "^10.1.0",
    "ora": "^8.2.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
